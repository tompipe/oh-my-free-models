{
  "name": "oh-my-free-models",
  "version": "0.0.3",
  "description": "Route your coding agent to the fastest free LLM in real time.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hakilee/oh-my-free-models.git"
  },
  "homepage": "https://github.com/hakilee/oh-my-free-models",
  "bugs": "https://github.com/hakilee/oh-my-free-models/issues",
  "type": "module",
  "bin": {
    "omfm": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE.md",
    "oh-my-free-models-character.png"
  ],
  "scripts": {
    "docs:check": "node scripts/check-docs.mjs",
    "metadata:update": "node scripts/update-model-metadata.mjs",
    "version:generate": "node scripts/generate-version.mjs",
    "prebuild": "node scripts/generate-version.mjs",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "node scripts/generate-version.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "node scripts/generate-version.mjs",
    "test": "vitest run",
    "predev": "node scripts/generate-version.mjs",
    "dev": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
