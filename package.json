{
  "name": "oh-my-free-models",
  "version": "0.0.1",
  "description": "Route your coding agent to the fastest free LLM in real time.",
  "type": "module",
  "bin": {
    "omfm": "dist/cli.js"
  },
  "files": [
    "dist",
    "data/model-metadata.json",
    "docs",
    "README.md",
    "oh-my-free-models-character.png"
  ],
  "scripts": {
    "docs:check": "node scripts/check-docs.mjs",
    "metadata:update": "node scripts/update-model-metadata.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
